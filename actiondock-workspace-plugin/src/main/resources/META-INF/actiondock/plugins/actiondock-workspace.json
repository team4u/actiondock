{
  "pluginId": "actiondock-workspace",
  "name": "ActionDock Workspace",
  "description": "Built-in workspace system plugin for controlled file-system and shell operations from scripts.",
  "actions": [
    {
      "action": "listDirectory",
      "title": "List Directory",
      "description": "List directories and files under a workspace path.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "title": "Directory Path"
          },
          "baseDir": {
            "type": "string",
            "title": "Base Directory"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "dirPath": {
            "type": "string"
          },
          "directories": {
            "type": "array"
          },
          "files": {
            "type": "array"
          },
          "directoryCount": {
            "type": "integer"
          },
          "fileCount": {
            "type": "integer"
          }
        }
      },
      "exampleArgs": {
        "path": "."
      }
    },
    {
      "action": "viewTextFile",
      "title": "View Text File",
      "description": "Read text content from a file with optional line ranges.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "title": "File Path"
          },
          "viewRange": {
            "type": "string",
            "title": "Line Range"
          },
          "baseDir": {
            "type": "string",
            "title": "Base Directory"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "filePath": {
            "type": "string"
          },
          "startLine": {
            "type": "integer"
          },
          "endLine": {
            "type": "integer"
          },
          "lineCount": {
            "type": "integer"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "exampleArgs": {
        "path": "README.md",
        "viewRange": "1,20"
      }
    },
    {
      "action": "writeTextFile",
      "title": "Write Text File",
      "description": "Create, overwrite, or replace a text file range.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "title": "File Path"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "ranges": {
            "type": "string",
            "title": "Replace Range"
          },
          "baseDir": {
            "type": "string",
            "title": "Base Directory"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "filePath": {
            "type": "string"
          },
          "created": {
            "type": "boolean"
          },
          "replacedRange": {
            "type": "array"
          },
          "snippet": {
            "type": "string"
          },
          "snippetRange": {
            "type": "array"
          }
        }
      },
      "exampleArgs": {
        "path": "notes.txt",
        "content": "updated line",
        "ranges": "2,3"
      }
    },
    {
      "action": "insertTextFile",
      "title": "Insert Text File",
      "description": "Insert text content into a file at a specific line.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "title": "File Path"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "lineNumber": {
            "type": "integer",
            "title": "Line Number"
          },
          "baseDir": {
            "type": "string",
            "title": "Base Directory"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "filePath": {
            "type": "string"
          },
          "lineNumber": {
            "type": "integer"
          },
          "snippet": {
            "type": "string"
          },
          "snippetRange": {
            "type": "array"
          }
        }
      },
      "exampleArgs": {
        "path": "notes.txt",
        "content": "inserted line",
        "lineNumber": 3
      }
    },
    {
      "action": "getSystemInfo",
      "title": "Get System Info",
      "description": "Inspect the current system, workspace, available shells, and common command runtimes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "baseDir": {
            "type": "string",
            "title": "Base Directory"
          },
          "shellPath": {
            "type": "string",
            "title": "Shell Path"
          },
          "additionalCommands": {
            "type": "array",
            "title": "Additional Commands",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "workspace": {
            "type": "object"
          },
          "system": {
            "type": "object"
          },
          "pathEntries": {
            "type": "array"
          },
          "shells": {
            "type": "array"
          },
          "commands": {
            "type": "array"
          }
        }
      },
      "exampleArgs": {
        "baseDir": ".",
        "additionalCommands": [
          "docker",
          "uv"
        ]
      }
    },
    {
      "action": "executeShellCommand",
      "title": "Execute Shell Command",
      "description": "Execute a shell command inside the workspace with optional timeouts and command restrictions. Bash is the preferred shell on all platforms: on Linux/macOS it uses bash directly; on Windows it tries Git Bash first and only falls back to PowerShell or cmd.exe if bash is unavailable. Use 'shellPath' to override the default shell, or 'allowedCommands' to restrict which commands may run.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "title": "Command",
            "description": "The shell command string to execute. Prefer bash syntax for cross-platform compatibility."
          },
          "cwd": {
            "type": "string",
            "title": "Working Directory",
            "description": "Working directory for command execution. Defaults to baseDir if not specified."
          },
          "timeoutSeconds": {
            "type": "integer",
            "title": "Timeout Seconds",
            "description": "Maximum execution time in seconds. The process is killed if it exceeds this limit. Default: 30."
          },
          "maxOutputBytes": {
            "type": "integer",
            "title": "Max Output Bytes",
            "description": "Truncate combined stdout+stderr output to this many bytes to avoid memory issues. Default: 1048576 (1 MB)."
          },
          "allowedCommands": {
            "type": "array",
            "title": "Allowed Commands",
            "description": "If non-empty, only commands whose first token appears in this list are permitted. Use this to restrict the command surface.",
            "items": {
              "type": "string"
            }
          },
          "shellPath": {
            "type": "string",
            "title": "Shell Path",
            "description": "Explicit path to the shell executable. Overrides auto-detected shell (e.g. '/bin/bash', 'C:\\Program Files\\Git\\bin\\bash.exe')."
          },
          "baseDir": {
            "type": "string",
            "title": "Base Directory",
            "description": "Root directory for the workspace sandbox. Defaults to the filesystem root ('/' on Linux, drive root on Windows) if not specified."
          },
          "env": {
            "type": "object",
            "title": "Environment",
            "description": "Additional environment variables to set for the child process, as key-value pairs. These are merged with the current process environment."
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "command": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "exitCode": {
            "type": "integer"
          },
          "stdout": {
            "type": "string"
          },
          "stderr": {
            "type": "string"
          },
          "durationMs": {
            "type": "integer"
          },
          "timedOut": {
            "type": "boolean"
          }
        }
      },
      "exampleArgs": {
        "command": "ls -la",
        "cwd": ".",
        "timeoutSeconds": 10
      }
    }
  ]
}
