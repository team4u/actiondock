{
  "name": "actiondock",
  "version": "0.1.33",
  "description": "ActionDock local automation runtime, CLI, server, admin UI, and desktop tray app",
  "license": "MIT",
  "type": "module",
  "preferGlobal": true,
  "bin": {
    "actiondock": "./bin/run.js",
    "actiondock-runtime": "./bin/actiondock-runtime.cjs"
  },
  "files": [
    "bin",
    "dist",
    "jdeploy-bundle",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run clean:dist && tsc -p tsconfig.json",
    "clean:dist": "node ./scripts/clean-dist.mjs",
    "clean": "node ./scripts/clean.mjs",
    "dev": "NODE_OPTIONS='--import tsx' node ./bin/dev.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "jdeploy:package": "jdeploy package && node ./scripts/patch-jdeploy-bundle.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build && npm run build:runtime && npm run jdeploy:package && cp ../README.md ./README.md"
  },
  "dependencies": {
    "@oclif/core": "^4.10.6",
    "@oclif/plugin-autocomplete": "^3.2.46",
    "@oclif/plugin-warn-if-update-available": "^3.1.61",
    "command-exists-promise": "^2.0.2",
    "node-fetch": "2.6.7",
    "shelljs": "^0.10.0",
    "tar": "^7.5.15",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jdeploy": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.3"
  },
  "oclif": {
    "bin": "actiondock",
    "dirname": "actiondock",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "warn-if-update-available": {
      "timeoutInDays": 1,
      "frequency": 1,
      "frequencyUnit": "days",
      "message": "ActionDock update available from <%= config.version %> to <%= latest %>. Run: npm install -g actiondock@latest"
    },
    "plugins": [
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-warn-if-update-available"
    ]
  },
  "jdeploy": {
    "javaVersion": "21",
    "jar": "runtime/actiondock-app-spring.jar",
    "title": "ActionDock",
    "args": [
      "-Dfile.encoding=UTF-8"
    ],
    "commands": {
      "actiondock-runtime": {
        "description": "ActionDock local runtime service",
        "args": [
          "--actiondock-runtime"
        ],
        "implements": [
          "updater",
          "uninstaller"
        ],
        "embedPlist": true
      }
    },
    "helper": {
      "actions": [
        {
          "label": "Open Admin Console",
          "description": "Open ActionDock admin console",
          "url": "http://127.0.0.1:5177/admin/app/scripts"
        },
        {
          "label": "Health Check",
          "description": "Open ActionDock health endpoint",
          "url": "http://127.0.0.1:5177/actuator/health"
        }
      ]
    },
    "singleton": true
  }
}
