{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocumentSetPlanA",
  "type": "object",
  "required": [
    "plan_id",
    "status",
    "source_domain_plans",
    "merge_policy",
    "execution_scope",
    "coverage_summary",
    "documents",
    "excluded_candidates",
    "merge_decisions",
    "self_check"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL_REPAIRABLE",
        "FAIL_NEEDS_REPLAN",
        "BLOCKED",
        "INSUFFICIENT_EVIDENCE",
        "UNAVAILABLE"
      ]
    },
    "source_domain_plans": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "merge_policy": {
      "const": "preserving_merge_not_compression"
    },
    "execution_scope": {
      "type": "object",
      "required": [
        "mode",
        "default_categories",
        "candidate_policy"
      ],
      "properties": {
        "mode": {
          "enum": [
            "default",
            "high_coverage",
            "repair",
            "manual_scope"
          ]
        },
        "default_categories": {
          "type": "array",
          "items": {
            "enum": [
              "existing",
              "must",
              "should",
              "candidate",
              "defer",
              "excluded"
            ]
          }
        },
        "candidate_policy": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "coverage_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_path",
          "domain",
          "category",
          "doc_type",
          "reason",
          "evidence_basis",
          "expected_content",
          "acceptance_criteria",
          "phase"
        ],
        "properties": {
          "target_path": {
            "type": "string"
          },
          "domain": {
            "enum": [
              "architecture",
              "api",
              "data",
              "business_flow",
              "agent_tool",
              "infra_env",
              "maintenance_ops",
              "other"
            ]
          },
          "category": {
            "enum": [
              "existing",
              "must",
              "should",
              "candidate",
              "defer",
              "excluded"
            ]
          },
          "doc_type": {
            "enum": [
              "actiondock",
              "index",
              "leaf",
              "runbook",
              "reference",
              "other"
            ]
          },
          "reason": {
            "type": "string"
          },
          "evidence_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_content": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "phase": {
            "type": "integer",
            "minimum": 0
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_eligibility": {
            "enum": [
              "execute_default",
              "execute_high_coverage",
              "defer",
              "exclude"
            ]
          },
          "source_domain_plan": {
            "type": "string"
          },
          "merge_action": {
            "enum": [
              "preserved",
              "merged",
              "renamed",
              "deduped",
              "deferred",
              "excluded"
            ]
          },
          "merge_reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "excluded_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_path",
          "domain",
          "category",
          "doc_type",
          "reason",
          "evidence_basis",
          "expected_content",
          "acceptance_criteria",
          "phase"
        ],
        "properties": {
          "target_path": {
            "type": "string"
          },
          "domain": {
            "enum": [
              "architecture",
              "api",
              "data",
              "business_flow",
              "agent_tool",
              "infra_env",
              "maintenance_ops",
              "other"
            ]
          },
          "category": {
            "enum": [
              "existing",
              "must",
              "should",
              "candidate",
              "defer",
              "excluded"
            ]
          },
          "doc_type": {
            "enum": [
              "actiondock",
              "index",
              "leaf",
              "runbook",
              "reference",
              "other"
            ]
          },
          "reason": {
            "type": "string"
          },
          "evidence_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_content": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "phase": {
            "type": "integer",
            "minimum": 0
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_eligibility": {
            "enum": [
              "execute_default",
              "execute_high_coverage",
              "defer",
              "exclude"
            ]
          },
          "source_domain_plan": {
            "type": "string"
          },
          "merge_action": {
            "enum": [
              "preserved",
              "merged",
              "renamed",
              "deduped",
              "deferred",
              "excluded"
            ]
          },
          "merge_reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "merge_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_domain_plan",
          "source_target_path",
          "decision",
          "reason"
        ],
        "properties": {
          "source_domain_plan": {
            "type": "string"
          },
          "source_target_path": {
            "type": "string"
          },
          "decision": {
            "enum": [
              "preserved",
              "merged",
              "renamed",
              "deduped",
              "deferred",
              "excluded",
              "blocked"
            ]
          },
          "result_target_path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "self_check": {
      "type": "object",
      "required": [
        "all_activated_domains_merged",
        "no_missing_domain_plans",
        "no_inventory_compression",
        "should_docs_preserved_or_explained",
        "no_index_content_sink",
        "no_active_domain_index_only",
        "no_obvious_underplanning",
        "worker_discovery_not_required_for_main_structure"
      ],
      "properties": {
        "all_activated_domains_merged": {
          "type": "boolean"
        },
        "no_missing_domain_plans": {
          "type": "boolean"
        },
        "no_inventory_compression": {
          "type": "boolean"
        },
        "should_docs_preserved_or_explained": {
          "type": "boolean"
        },
        "no_index_content_sink": {
          "type": "boolean"
        },
        "no_active_domain_index_only": {
          "type": "boolean"
        },
        "no_obvious_underplanning": {
          "type": "boolean"
        },
        "worker_discovery_not_required_for_main_structure": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
