{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StageResult",
  "type": "object",
  "required": [
    "stage",
    "status",
    "success_criteria",
    "criteria_results",
    "evidence",
    "outputs",
    "open_issues",
    "next_action"
  ],
  "properties": {
    "stage": {
      "type": "string"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL_REPAIRABLE",
        "FAIL_NEEDS_REPLAN",
        "BLOCKED",
        "INSUFFICIENT_EVIDENCE",
        "UNAVAILABLE"
      ]
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "status",
          "evidence",
          "notes"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "UNKNOWN",
              "NOT_APPLICABLE"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "object"
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "enum": [
        "CONTINUE",
        "REPAIR",
        "REPLAN",
        "VALIDATE",
        "FINALIZE",
        "STOP_BLOCKED"
      ]
    }
  },
  "additionalProperties": false
}
