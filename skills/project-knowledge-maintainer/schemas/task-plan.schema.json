{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskPlanB",
  "type": "object",
  "required": [
    "plan_b_id",
    "derived_from_plan_a",
    "execution_scope",
    "phases",
    "skipped_plan_a_documents"
  ],
  "properties": {
    "plan_b_id": {
      "type": "string"
    },
    "derived_from_plan_a": {
      "type": "string"
    },
    "execution_scope": {
      "type": "object",
      "required": [
        "mode",
        "included_categories"
      ],
      "properties": {
        "mode": {
          "enum": [
            "default",
            "high_coverage",
            "repair",
            "manual_scope"
          ]
        },
        "included_categories": {
          "type": "array",
          "items": {
            "enum": [
              "existing",
              "must",
              "should",
              "candidate",
              "defer",
              "excluded"
            ]
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "purpose",
          "tasks"
        ],
        "properties": {
          "phase": {
            "type": "integer",
            "minimum": 0
          },
          "purpose": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "task_id",
                "target_path",
                "category",
                "delegate",
                "acceptance_criteria",
                "plan_a_ref"
              ],
              "properties": {
                "task_id": {
                  "type": "string"
                },
                "target_path": {
                  "type": "string"
                },
                "category": {
                  "enum": [
                    "existing",
                    "must",
                    "should",
                    "candidate",
                    "defer",
                    "excluded"
                  ]
                },
                "delegate": {
                  "enum": [
                    "subagent",
                    "serial"
                  ]
                },
                "inputs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "acceptance_criteria": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "plan_a_ref": {
                  "type": "string"
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "skipped_plan_a_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_path",
          "category",
          "reason"
        ],
        "properties": {
          "target_path": {
            "type": "string"
          },
          "category": {
            "enum": [
              "existing",
              "must",
              "should",
              "candidate",
              "defer",
              "excluded"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
